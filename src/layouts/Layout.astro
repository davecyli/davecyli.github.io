---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrapper">
      <aside class="sidebar">
        <h1><a href="/">{title}</a></h1>
        <img src="/images/logo.png" alt="David Li" width="142" height="150" />
        <p>
          BS Mechanical Engineering (Mechatronics)<br />
          MS Electrical Engineering (Control Systems)
        </p>
        <p>
          <a href="https://www.linkedin.com/in/davecyli/">LinkedIn</a> &middot;
          <a href="https://github.com/davecyli">GitHub</a>
        </p>
      </aside>
      <main>
        <slot />
      </main>
    </div>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        color: #333;
        line-height: 1.6;
        padding: 2rem;
      }

      .wrapper {
        max-width: 860px;
        margin: 0 auto;
        display: flex;
        gap: 3rem;
      }

      .sidebar {
        width: 200px;
        flex-shrink: 0;
      }

      .sidebar h1 {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
      }

      .sidebar h1 a {
        color: #333;
        text-decoration: none;
      }

      .sidebar img {
        display: block;
        margin-bottom: 0.75rem;
        border-radius: 4px;
      }

      .sidebar p {
        font-size: 0.85rem;
        color: #555;
        margin-bottom: 0.5rem;
      }

      .sidebar a {
        color: #4078c0;
        text-decoration: none;
      }

      .sidebar a:hover {
        text-decoration: underline;
      }

      main {
        flex: 1;
        min-width: 0;
      }

      main :global(h2) {
        font-size: 1.25rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 0.3rem;
        margin-bottom: 1rem;
      }

      main :global(h2 + h2) {
        margin-top: 2rem;
      }

      main :global(p) {
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
      }

      main :global(a) {
        color: #4078c0;
        text-decoration: none;
        font-weight: 500;
      }

      main :global(a:hover) {
        text-decoration: underline;
      }

      main :global(ul) {
        list-style: none;
        padding: 0;
        margin-bottom: 1rem;
      }

      main :global(li) {
        font-size: 0.9rem;
        color: #555;
        margin-bottom: 0.25rem;
      }

      main :global(hr) {
        border: none;
        border-top: 1px solid #eee;
        margin: 1.5rem 0;
      }

      @media (max-width: 600px) {
        .wrapper {
          flex-direction: column;
          gap: 1.5rem;
        }

        .sidebar {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
